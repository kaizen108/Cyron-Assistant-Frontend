# Backend API (VPS)
VITE_API_BASE_URL=https://api.cyronticket.com

# Frontend public URL (Vercel)
VITE_FRONTEND_BASE_URL=https://cyron-frontend.vercel.app

# Must match a URI in backend DISCORD_OAUTH_ALLOWED_REDIRECT_URIS and Discord Developer Portal OAuth2 redirects
VITE_DISCORD_OAUTH_REDIRECT=https://cyron-frontend.vercel.app/auth/callback

# Discord bot invite link (replace client_id with your application ID)
VITE_DISCORD_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=8&integration_type=0&scope=applications.commands+bot
