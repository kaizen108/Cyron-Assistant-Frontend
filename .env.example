# Vercel: set these in Project Settings → Environment Variables, then redeploy.

VITE_API_BASE_URL=https://api.cyronticket.com
VITE_FRONTEND_BASE_URL=https://cyron-assistant-frontend.vercel.app
VITE_DISCORD_OAUTH_REDIRECT=https://cyron-assistant-frontend.vercel.app/auth/callback
VITE_DISCORD_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=8&integration_type=0&scope=applications.commands+bot
